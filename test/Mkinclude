# System: set SYSTEM to match your environment, or override on command line
# Available: Linux64-gnu-ompi, Linux64-intel-impi, Linux64-intel-ompi,
#            MacOSX-gnu-ompi, yumyum-gnu, yumyum-intel, wink-intel, ...
SYSTEM ?= Linux64-gnu-ompi

# TOPDIR must point to the test/ directory (set by the including Makefile):
#   test/Makefile      -> TOPDIR = .
#   test/src/Makefile  -> TOPDIR = ..
#   test/run/Makefile  -> TOPDIR = ..

# Output directories (relative to TOPDIR = test/)
BINDIR  = $(TOPDIR)/bin
LIBDIR  = $(TOPDIR)/lib
MODDIR  = $(TOPDIR)/include

# JcupLT source directory and library
JLTSRCDIR = $(TOPDIR)/../src
JLTLIB    = $(LIBDIR)/libjlt.a

# Include system-dependent settings
include $(TOPDIR)/sysdep/Makedef.$(SYSTEM)

ifeq ($(ILS_DEBUG),T)
   FFLAGS = $(FFLAGS_DEBUG)
else
   FFLAGS = $(FFLAGS_FAST)
endif
